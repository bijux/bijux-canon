# Unified release workflow configuration.
#
# Tag releases are orchestrated by
# .github/workflows/release-orchestrator.yml, which calls release-pypi.yml,
# release-ghcr.yml, and release-github.yml as reusable workflows. Keep direct
# push-triggered release workflows disabled here to avoid duplicate publication
# runs.
BIJUX_RELEASE_ENABLED=false
BIJUX_GHCR_RELEASE_ENABLED=false
BIJUX_PYPI_ENABLED=false
