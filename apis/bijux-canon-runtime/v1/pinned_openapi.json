{
  "components": {
    "schemas": {
      "FailureEnvelope": {
        "additionalProperties": false,
        "description": "Failure envelope; misuse breaks error contract.",
        "properties": {
          "determinism_impact": {
            "enum": [
              "structural",
              "environmental",
              "stochastic",
              "human",
              "external"
            ],
            "title": "Determinism Impact",
            "type": "string"
          },
          "evidence_ids": {
            "items": {
              "type": "string"
            },
            "title": "Evidence Ids",
            "type": "array"
          },
          "failure_class": {
            "enum": [
              "structural",
              "semantic",
              "environmental",
              "authority"
            ],
            "title": "Failure Class",
            "type": "string"
          },
          "reason_code": {
            "const": "contradiction_detected",
            "title": "Reason Code",
            "type": "string"
          },
          "violated_contract": {
            "title": "Violated Contract",
            "type": "string"
          }
        },
        "required": [
          "failure_class",
          "reason_code",
          "violated_contract",
          "evidence_ids",
          "determinism_impact"
        ],
        "title": "FailureEnvelope",
        "type": "object"
      },
      "FlowRunRequest": {
        "additionalProperties": false,
        "description": "Flow run request; misuse breaks API contract.",
        "properties": {
          "dataset_id": {
            "title": "Dataset Id",
            "type": "string"
          },
          "flow_manifest": {
            "title": "Flow Manifest",
            "type": "string"
          },
          "inputs_fingerprint": {
            "title": "Inputs Fingerprint",
            "type": "string"
          },
          "policy_fingerprint": {
            "title": "Policy Fingerprint",
            "type": "string"
          },
          "run_mode": {
            "enum": [
              "live",
              "dry",
              "observer"
            ],
            "title": "Run Mode",
            "type": "string"
          }
        },
        "required": [
          "flow_manifest",
          "inputs_fingerprint",
          "run_mode",
          "dataset_id",
          "policy_fingerprint"
        ],
        "title": "FlowRunRequest",
        "type": "object"
      },
      "FlowRunResponse": {
        "additionalProperties": false,
        "description": "Flow run response; misuse breaks API contract.",
        "properties": {
          "artifact_count": {
            "title": "Artifact Count",
            "type": "integer"
          },
          "determinism_class": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Determinism class classification when available.",
            "title": "Determinism Class"
          },
          "environment_fingerprint": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Environment fingerprint when available.",
            "title": "Environment Fingerprint"
          },
          "flow_id": {
            "title": "Flow Id",
            "type": "string"
          },
          "replay_acceptability": {
            "enum": [
              "exact_match",
              "invariant_preserving",
              "statistically_bounded"
            ],
            "title": "Replay Acceptability",
            "type": "string"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "status": {
            "enum": [
              "completed",
              "failed",
              "cancelled"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "flow_id",
          "status",
          "replay_acceptability",
          "artifact_count"
        ],
        "title": "FlowRunResponse",
        "type": "object"
      },
      "HealthResponse": {
        "additionalProperties": false,
        "description": "Health response; misuse breaks API contract.",
        "properties": {
          "status": {
            "const": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ReadyResponse": {
        "additionalProperties": false,
        "description": "Readiness response; misuse breaks API contract.",
        "properties": {
          "ready": {
            "title": "Ready",
            "type": "boolean"
          }
        },
        "required": [
          "ready"
        ],
        "title": "ReadyResponse",
        "type": "object"
      },
      "ReplayRequest": {
        "additionalProperties": false,
        "description": "Replay request; misuse breaks API contract.",
        "properties": {
          "acceptability_threshold": {
            "enum": [
              "exact_match",
              "invariant_preserving",
              "statistically_bounded"
            ],
            "title": "Acceptability Threshold",
            "type": "string"
          },
          "expected_plan_hash": {
            "title": "Expected Plan Hash",
            "type": "string"
          },
          "observer_mode": {
            "title": "Observer Mode",
            "type": "boolean"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          }
        },
        "required": [
          "run_id",
          "expected_plan_hash",
          "acceptability_threshold",
          "observer_mode"
        ],
        "title": "ReplayRequest",
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "name": "Bijux",
      "url": "https://github.com/bijux/bijux-canon"
    },
    "description": "The bijux-canon-runtime HTTP API exposes the v1 execution and replay surface for flow contracts. It keeps required headers, request envelopes, and replay acceptability visible at the boundary so failures are reviewable rather than implicit.",
    "license": {
      "name": "Apache 2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    },
    "summary": "Contract-enforced execution and replay for the runtime layer.",
    "title": "bijux-canon-runtime API",
    "version": "v1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/flows/replay": {
      "post": {
        "description": "Preconditions: required headers are present, determinism level is valid, and the replay request is well-formed; acceptable replay means differences stay within the declared acceptability threshold; mismatches return FailureEnvelope with failure_class set to authority.",
        "operationId": "replay_flow_api_v1_flows_replay_post",
        "parameters": [
          {
            "in": "header",
            "name": "X-Agentic-Gate",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9._:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Agentic-Gate"
            }
          },
          {
            "in": "header",
            "name": "X-Determinism-Level",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9._:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Determinism-Level"
            }
          },
          {
            "in": "header",
            "name": "X-Policy-Fingerprint",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9._:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Policy-Fingerprint"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReplayRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlowRunResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Request body could not be parsed."
          },
          "406": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Required runtime headers are missing or invalid."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Request validation failed."
          },
          "501": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Flow execution or replay is not implemented yet."
          }
        },
        "summary": "Replay Flow",
        "tags": [
          "Flows"
        ]
      }
    },
    "/api/v1/flows/run": {
      "post": {
        "description": "Deterministic guarantees cover declared contracts and persisted envelopes only; runtime environment, external tools, and policy omissions are explicitly not guaranteed; replay equivalence is expected to fail when headers, policy fingerprints, or dataset identity diverge from the declared contract.",
        "operationId": "run_flow_api_v1_flows_run_post",
        "parameters": [
          {
            "in": "header",
            "name": "X-Agentic-Gate",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9._:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Agentic-Gate"
            }
          },
          {
            "in": "header",
            "name": "X-Determinism-Level",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9._:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Determinism-Level"
            }
          },
          {
            "in": "header",
            "name": "X-Policy-Fingerprint",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9._:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Policy-Fingerprint"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlowRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlowRunResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Request body could not be parsed."
          },
          "406": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Required runtime headers are missing or invalid."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Request validation failed."
          },
          "501": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailureEnvelope"
                }
              }
            },
            "description": "Flow execution or replay is not implemented yet."
          }
        },
        "summary": "Run Flow",
        "tags": [
          "Flows"
        ]
      }
    },
